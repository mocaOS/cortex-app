# =============================================================================
# Cortex — Recommended Minimal .env (bench-validated on Venice)
# =============================================================================
# Copy to .env, fill in the secrets block + your API key, and you're done:
#
#   cp .env.recommended .env
#
# Everything not listed here runs on production-tuned code defaults.
# Notes explaining each block are at the bottom of this file.
# Full configuration reference: https://docs.cortex.eco/configuration
# =============================================================================

# ── Admin authentication + secrets ──────────────────────────────────────────
# Generate each secret fresh — do NOT ship these placeholder values. With
# ENVIRONMENT=production (below) the backend refuses to boot on a weak/placeholder
# secret. Generate strong values with:  openssl rand -hex 32

ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ADMIN_API_KEY=CHANGE_ME_run_openssl_rand_hex_32
SERVICE_PASSWORD_NEO4J=CHANGE_ME_strong_neo4j_password
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32
# Fernet key for at-rest encryption of git PATs & skill secrets. Leave empty to
# store them unencrypted; generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ENVIRONMENT=production

# ── Primary LLM — agentic Q&A / research / chat ──────────────────────────────

OPENAI_API_KEY=your-api-key
OPENAI_API_BASE=https://api.venice.ai/api/v1
OPENAI_MODEL=google-gemma-4-26b-a4b-it
OPENAI_MAX_CONTEXT=256000

# ── Embeddings ────────────────────────────────────────────────────────────────

EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_API_BASE=
# EMBEDDING_API_KEY=

# ── Vision — image analysis during document ingestion ───────────────────────

VISION_MODEL=qwen3-6-27b
# VISION_MODEL_API_BASE=
# VISION_MODEL_API_KEY=

# ── Graph extraction — entities + relationships ──────────────────────────────

GRAPH_EXTRACTION_MODEL=qwen3-6-27b
# GRAPH_EXTRACTION_API_BASE=
# GRAPH_EXTRACTION_API_KEY=

# ── Uploads ───────────────────────────────────────────────────────────────────

# MAX_FILE_SIZE_MB=100

# ── x402 Payments — pay-per-query monetization (optional) ────────────────────
# Set true to unlock the "x402 Payments" section on the admin Settings page;
# wallet/facilitator/network/asset are configured there at runtime (no env).
# X402_ENABLED=true

# =============================================================================
# Notes
# =============================================================================
# * Secrets: generate strong values for production (`openssl rand -base64 32`).
#   SESSION_SECRET must be ≥ 32 chars. SERVICE_PASSWORD_NEO4J is the Neo4j auth
#   string (wired into NEO4J_AUTH + NEO4J_PASSWORD by docker-compose.yml).
#   Uncomment ENVIRONMENT=production to enforce strong secrets at startup and
#   auto-disable the interactive API docs (/docs, /openapi.json).
#
# * ENCRYPTION_KEY encrypts user-supplied secrets at rest (git connector PATs,
#   secret-typed skill config fields). Left empty they are stored in PLAINTEXT
#   (a warning is logged at startup); setting a key later auto-encrypts existing
#   plaintext secrets on the next startup. Generate one:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Rotation (zero downtime): ENCRYPTION_KEY=<new-key>,<old-key> → restart → drop old.
#
# * The model stack: Gemma4 26B A4B is the bench-validated primary — a fast
#   26B/4B-active MoE, ideal for retrieval — and qwen3-6-27b covers both
#   extraction and vision from a single endpoint. Any OpenAI-compatible
#   provider hosting these works (Venice, OpenRouter, self-hosted vLLM).
#   VISION_MODEL must be set explicitly (it does not inherit a model name);
#   left empty, Cortex falls back to Docling's built-in captioning.
#
# * OPENAI_MAX_CONTEXT is the primary model's input window (256000 = Gemma4
#   26B A4B) and only applies to chat/research. You do NOT need to set context
#   windows for the extraction or vision models — ingestion runs on its own
#   fine-tuned budgets (16000/16000 by default, sized to provider decode speed
#   rather than the model window).
#
# * Every *_API_BASE / *_API_KEY pair inherits from OPENAI_API_BASE /
#   OPENAI_API_KEY. Uncomment a pair to pull that tier from a different
#   provider.
#
# * EMBEDDING_DIMENSION=1536 is the default, matched to text-embedding-3-small.
#   Change it together with the embedding model — bumping the dimension
#   triggers a re-embed of existing documents.
#
# * MAX_FILE_SIZE_MB defaults to 50. Raise it only if your host has the RAM
#   for heavier Docling conversions on large documents.
#
# * Ingestion concurrency (batch/extraction/relations/vision) ships at its
#   production-measured optimum — raising it usually makes multi-document
#   builds SLOWER (provider throughput collapses). Leave it alone.
#
# * Need any other knob? .env.example holds the full 160+ var reference, or
#   see https://docs.cortex.eco/configuration
# =============================================================================
