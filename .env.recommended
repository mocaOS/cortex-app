# =============================================================================
# Cortex — Recommended Minimal .env (bench-validated against Venice)
# =============================================================================
# Copy to .env, swap the secrets, and you're done:
#
#   cp .env.recommended .env
#   # edit OPENAI_API_KEY + the four ADMIN / SESSION / SERVICE secrets
#
# Why it's minimal: the model + budget fallback chains in config.py let three
# model tiers run off two model names. Embedding API base/key inherit from
# OPENAI_* automatically when blank.
#
# For every available knob (40+ vars), see .env.example or https://docs.cortex.eco
# =============================================================================


# -----------------------------------------------------------------------------
# Primary LLM — agentic Q&A / research / chat
# -----------------------------------------------------------------------------
# MiniMax-M27 is the bench-validated primary for Q&A / research. Any
# OpenAI-compatible provider hosting it works (Venice, OpenRouter,
# self-hosted vLLM, Compute3). Keep MiniMax confined to this tier — it
# inlines <think> tokens on ingestion paths despite disable_thinking,
# so extraction/vision stay on qwen3-6-27b below.

OPENAI_API_KEY=your-venice-or-openrouter-key
OPENAI_API_BASE=https://api.venice.ai/api/v1
OPENAI_MODEL=minimax-m27
OPENAI_MAX_CONTEXT=196608          # MiniMax-M27's 192K input window


# -----------------------------------------------------------------------------
# Graph extraction tier — drives relationship analysis via inheritance
# -----------------------------------------------------------------------------
# Qwen3.7-27B for verbose-XML entity/relationship extraction.
# RELATIONSHIP_EXTRACTION_MODEL inherits this automatically.

GRAPH_EXTRACTION_MODEL=qwen3-6-27b
GRAPH_EXTRACTION_MAX_CONTEXT=256000   # Qwen3.7-27B's 256K window


# -----------------------------------------------------------------------------
# Vision model — image analysis during document ingestion
# -----------------------------------------------------------------------------
# VISION_MODEL does NOT inherit from the extraction tier — set it explicitly.
# api_base + api_key inherit from OPENAI_* automatically. Without VISION_MODEL,
# Cortex falls back to Docling's built-in SmolVLM (lower quality, no API call).

VISION_MODEL=qwen3-6-27b          # multimodal on Venice; same model as extraction (single endpoint)


# -----------------------------------------------------------------------------
# Embeddings — text embedding model
# -----------------------------------------------------------------------------
# Qwen3-Embedding-8B (native 4096, MRL 32–4096). Inherits primary API base/key.
# Neo4j 5.26 (this repo's pinned version) supports 4096-dim vector indexes.

EMBEDDING_MODEL=text-embedding-qwen3-8b
EMBEDDING_DIMENSION=4096
# Default EMBEDDING_MAX_INPUT_TOKENS=8192 fits Venice + OpenAI + most managed
# providers (they cap inputs at 8192 at the gateway, regardless of the
# underlying model's native context). Self-hosted vLLM users running
# Qwen3-Embedding-8B with the full 32K window can override:
#   EMBEDDING_MAX_INPUT_TOKENS=32768


# -----------------------------------------------------------------------------
# Performance tuning (Venice-validated)
# -----------------------------------------------------------------------------
# Safe on Venice / Compute3 / large vLLM. Dial CONCURRENT_EXTRACTIONS down
# first on smaller providers (biggest multiplier, heaviest call).

BATCH_PROCESSING_CONCURRENCY=3     # docs in parallel (default 2)
CONCURRENT_EXTRACTIONS=4           # entity-extraction threads per doc (default 3) — biggest multiplier
CONCURRENT_RELATIONS=4             # per-chunk relationship threads per doc (default 3)
VISION_MAX_CONCURRENT=4            # global vision-API semaphore (default 3)


# -----------------------------------------------------------------------------
# Admin authentication + secrets
# -----------------------------------------------------------------------------
# Generate strong values for production:  openssl rand -base64 32
# SESSION_SECRET must be ≥ 32 chars. SERVICE_PASSWORD_NEO4J is the Neo4j auth
# string (wired into NEO4J_AUTH + NEO4J_PASSWORD by docker-compose.yml).

ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=your-pass
ADMIN_API_KEY=custom-api-keyyy
SERVICE_PASSWORD_NEO4J=another-pass
SESSION_SECRET=secret              # use `openssl rand -base64 32` for production


# =============================================================================
# Need a knob that isn't here? See .env.example for the full reference,
# or https://docs.cortex.eco for the per-feature walkthrough.
# =============================================================================
