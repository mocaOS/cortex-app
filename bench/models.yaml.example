# Model registry for the benchmark orchestrator.
#
# Each entry describes ONE model end-to-end: the API model_id, the endpoint
# base_url, where to get the API key (env var name), and the context window.
#
# Referenced by analysis/bench/combos.yaml. A single model entry can be reused
# across many combos and across any of the three tiers (primary / extraction /
# relationship). This keeps combo definitions short and makes provider switches
# explicit.
#
# Required fields:
#   model_id        — the string the API expects
#   base_url        — full URL including /v1
#   context_length  — used to set EXTRACTION_MAX_CONTEXT / RELATIONSHIP_MAX_CONTEXT
#
# Auth (one of):
#   api_key_env: NAME  — orchestrator reads NAME from shell env, falls back to
#                        the live .env. PREFERRED — keeps secrets out of files.
#   api_key: "literal" — inline (acceptable since analysis/ is gitignored).
#
# Optional metadata (surfaced into run records + LLM review):
#   family             — qwen, mistral, llama, gemma, openai, anthropic, etc.
#   reasoning_capable  — true/false. Drives reasoning-mode interpretation.
#   max_output_tokens  — if set AND used at relationship tier, sets
#                        RELATIONSHIP_MAX_OUTPUT_TOKENS for the run.
#   note               — free-form human comment.

models:

  # ---------------- Venice — small dense instruct (extraction-friendly) -----

  mistral-24b-venice:
    model_id: mistral-small-3-2-24b-instruct
    base_url: https://api.venice.ai/api/v1
    api_key_env: OPENAI_API_KEY        # live .env uses OPENAI_API_KEY for the Venice key
    context_length: 256000
    family: mistral
    reasoning_capable: false
    note: "Cheapest dense 24B on Venice. Cleanest XML output baseline."

  venice-uncensored-1-2:
    model_id: venice-uncensored-1-2
    base_url: https://api.venice.ai/api/v1
    api_key_env: OPENAI_API_KEY
    context_length: 128000
    family: mistral
    reasoning_capable: false
