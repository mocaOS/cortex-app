FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for Docling (PDF/image processing requires X11 libs, OCR).
# gosu lets the entrypoint drop from root to the app user after fixing volume ownership.
# git is required by the Git Integration connector (git_connector_service spawns
# the git CLI for clone/fetch/diff) — without it every sync dies instantly with
# a bare "[Errno 2] No such file or directory" from create_subprocess_exec.
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    gosu \
    libxcb1 \
    libx11-6 \
    libxext6 \
    libxrender1 \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*

# Build variants:
#   default (INSTALL_LOCAL_ML=true)  — full image with local torch/docling/reranker
#   slim    (INSTALL_LOCAL_ML=false) — no torch (~800MB-1GB smaller); requires
#            OpenAI embeddings + cortex-helper (RERANKER_SERVICE_URL /
#            DOCLING_SERVICE_URL, recommended HELPER_STRICT_REMOTE=true)
ARG INSTALL_LOCAL_ML=true
ARG PREDOWNLOAD_MODELS=true

# Copy requirements first for better caching
COPY requirements.txt requirements-base.txt requirements-ml.txt ./

# Install Python dependencies (base always; ML stack only in the full image)
RUN pip install --no-cache-dir -r requirements-base.txt && \
    if [ "$INSTALL_LOCAL_ML" = "true" ]; then \
        pip install --no-cache-dir -r requirements-ml.txt; \
    fi

# Deterministic HF cache location, independent of container user.
# Mount a volume here in production to keep the cache across container restarts.
ENV HF_HOME=/app/.cache/huggingface

# Customer stacks must not phone home (haystack ships posthog telemetry).
ENV HAYSTACK_TELEMETRY_ENABLED=False

# Pre-download sentence-transformers + cross-encoder during build so a cold image
# (no cache volume) still works without a runtime HF download.
RUN if [ "$INSTALL_LOCAL_ML" = "true" ] && [ "$PREDOWNLOAD_MODELS" = "true" ]; then \
        python -c "from sentence_transformers import SentenceTransformer, CrossEncoder; \
SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2'); \
CrossEncoder('cross-encoder/ms-marco-MiniLM-L-6-v2')"; \
    fi

# Copy application code
COPY . .

# Create uploads and custom_inputs directories
RUN mkdir -p /app/uploads /app/custom_inputs

# Create the non-root user and chown the build-time tree. The runtime entrypoint
# re-applies ownership to the *volume mounts* (which shadow this chown), so we
# deliberately do NOT `USER appuser` here — the container must start as root for
# the entrypoint to chown root-owned volumes, then it drops to UID 1000 via gosu.
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app

# Entrypoint fixes volume ownership then drops privileges (see the script header).
RUN chmod +x /app/docker-entrypoint.sh

# Expose port
EXPOSE 8000

# Run with production settings (single worker to reduce memory usage)
# Increase workers via UVICORN_WORKERS env var if you have enough RAM (each worker uses ~1-2GB)
# --timeout-graceful-shutdown drains in-flight requests/SSE streams on SIGTERM
# (pair with compose stop_grace_period > this value).
# The CMD is passed as args to docker-entrypoint.sh, which execs it via gosu as UID 1000.
ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers ${UVICORN_WORKERS:-1} --timeout-graceful-shutdown 30"]
