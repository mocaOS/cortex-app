# =============================================================================
# Cortex - Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings

# =============================================================================
# QUICK START — Recommended Minimal Stack (bench-validated)
# =============================================================================
# Two models, everything else inherited via the budget chain.
# Requires a provider hosting both (OpenRouter, self-hosted vLLM,
# or any OpenAI-compatible router).
#
# Uncomment + fill in the two API values, then scroll down to set
# NEO4J_PASSWORD and the ADMIN_* / SESSION_SECRET block. That's it.

# Primary — agentic Q&A / researcher (Gemma4 26B A4B: fast MoE, 256K context window)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.venice.ai/api/v1
# OPENAI_MODEL=google-gemma-4-26b-a4b-it
# OPENAI_MAX_CONTEXT=256000

# Extraction — drives relationship via inheritance (Qwen3.6 27B: 256K window)
# GRAPH_EXTRACTION_MODEL=qwen3-6-27b
# GRAPH_EXTRACTION_MAX_CONTEXT=256000

# Vision — image analysis (does NOT inherit; api_base/api_key inherit from OPENAI_*)
# VISION_MODEL=qwen3-6-27b

# Embeddings — text embedding model (Qwen3-Embedding-8B: native 4096 dim, MRL-configurable 32–4096)
# Uses primary OPENAI_API_BASE + OPENAI_API_KEY unless EMBEDDING_API_BASE/_KEY are set.
# EMBEDDING_SEND_DIMENSIONS=true (default) works because Qwen3-Embedding-8B supports MRL.
# EMBEDDING_MODEL=text-embedding-qwen3-8b
# EMBEDDING_DIMENSION=4096   # Native dimension for Qwen3-Embedding-8B; supported by Neo4j 5.23+
                             # (this repo ships Neo4j 5.26 — see docker-compose.yml).
                             # Existing instances on Neo4j ≤ 5.20 with 1536/2048-dim corpora
                             # can keep their dim — Cortex preserves the index when EMBEDDING_DIMENSION
                             # matches the existing one. Only bumping the dim triggers a re-embed.
# Leave EMBEDDING_MAX_INPUT_TOKENS at default 8192 for managed providers — Venice
# and OpenAI cap embed inputs at 8192 at the API gateway regardless of model.
# Self-hosted vLLM users running Qwen3-Embedding-8B can lift it:
#   EMBEDDING_MAX_INPUT_TOKENS=32768

# -----------------------------------------------------------------------------
# Performance tuning (Venice-validated — pair these with the Recommended Stack above)
# -----------------------------------------------------------------------------
# Bench-validated against Venice as the LLM provider. Safe on Venice /
# large vLLM endpoints; dial back on stock OpenAI or smaller hosts.
# In practice the ingestion pipeline staggers entity extraction, per-chunk
# relationships, and vision across each doc's lifecycle, so actual concurrent
# in-flight calls stays well below the worst-case theoretical product.
#
# BATCH_PROCESSING_CONCURRENCY=3    # docs processed in parallel (default 2 — bump for batch ingestion)
# CONCURRENT_EXTRACTIONS=4          # entity-extraction threads per doc (default 3 — biggest multiplier)
# CONCURRENT_RELATIONS=4            # per-chunk relationship threads per doc (default 3)
# VISION_MAX_CONCURRENT=4           # system-wide vision-API semaphore (default 3)

# =============================================================================
# Deployment
# =============================================================================
# Set to "production" to enforce secret hardening at startup: the app refuses
# to boot with a default/empty NEO4J_PASSWORD or a SESSION_SECRET shorter than
# 32 chars (when ADMIN_PASSWORD is set). Leave as "development" for local runs.
ENVIRONMENT=development

# Allowed CORS origins, comma-separated (e.g.
# "https://app.example.com,https://admin.example.com"). The default "*" allows
# any origin but disables credentialed CORS (safe: auth is header-based via
# X-API-Key). Set an explicit allowlist for production.
CORS_ALLOWED_ORIGINS=*

# =============================================================================
# Core Services
# =============================================================================

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here

# OpenAI / LiteLLM Configuration
# Required for GraphRAG features (entity extraction, Q&A, summarization)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=google-gemma-4-26b-a4b-it
# OPENAI_MODEL_FAST_MODE=  # Optional: faster/cheaper model for "Fast Mode" in Ask AI (defaults to OPENAI_MODEL)

# Primary token budgets — sub-tiers (extraction / relationship / vision)
# inherit when their override is left at the default (0). This lets you
# configure a 3-model stack with just OPENAI_MODEL + GRAPH_EXTRACTION_MODEL
# and have everything else flow through. See the "Budget Fallback Chain"
# section further down for the full chain.
OPENAI_MAX_OUTPUT_TOKENS=8000      # Default output tokens for every LLM call
OPENAI_MAX_CONTEXT=32768           # Default input context budget

# =============================================================================
# Vision Model Configuration (Optional)
# =============================================================================
# Configure vision models for image extraction and analysis
# If not configured, system uses Docling's built-in descriptions or basic metadata

# Vision Model - Examples:
#   - OpenAI: gpt-4o, gpt-4-vision-preview
#   - Anthropic: claude-3-5-sonnet-20241022
#   - Local: llava (via Ollama)
# VISION_MODEL=gpt-4o

# Vision Model API Base URL (defaults to OPENAI_API_BASE if not set)
# VISION_MODEL_API_BASE=https://api.openai.com/v1

# Vision Model API Key (defaults to OPENAI_API_KEY if not set)
# VISION_MODEL_API_KEY=sk-your-vision-api-key-here

# Max concurrent vision API calls system-wide (default: 3)
# Increase for faster image-heavy document processing. Each slot uses one thread.
# VISION_MAX_CONCURRENT=3

# Minimum image side (pixels) before the analyzer attempts a vision-API call.
# PDFs often expose ~10–40 px bullets, icons, and separators as PictureItems;
# hosted vision APIs reject these (Venice returns HTTP 400 "did not pass validation
# checks" under ~64 px). Skip them client-side to save API spend and avoid 3-retry
# failure cascades. Set 0 to disable the pre-filter.
# VISION_MIN_IMAGE_SIDE=64

# Maximum image side (pixels) before the data-URL encode. Cortex renders PDF pages
# at 2× DPI (typical 2400×1700) — without downscaling the base64 blob bloats into
# hundreds of KB. Some providers (LiteLLM-wrapped vLLM, custom deployments)
# tokenize the base64 payload as TEXT and hit context-window caps as a result
# (one customer saw 184K-token vision inputs). 1568 matches Claude's recommended
# max side: high enough for OCR-grade text legibility, low enough to keep
# payloads safely under ~700 KB at JPEG q85. Set 0 to disable downscaling.
# VISION_MAX_IMAGE_SIDE=1568

# JPEG quality (1–95) when encoding opaque images for the vision API. 85 is the
# standard quality/size sweet spot — visually near-lossless for documents at
# ~5–10× smaller than PNG. PNG is still used automatically for images with an
# alpha channel.
# VISION_JPEG_QUALITY=85

# Vision output budget override (0 = inherit from RELATIONSHIP → EXTRACTION → OPENAI).
# Bump when using verbose multimodal models (Qwen3-VL, GLM-V) on complex images.
# VISION_MAX_OUTPUT_TOKENS=0

# =============================================================================
# Embedding Configuration
# =============================================================================

EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_SEND_DIMENSIONS=true        # Set to false for models with fixed output dimensions (e.g. qwen3-vl-embedding-2b)
# EMBEDDING_MAX_INPUT_TOKENS=8192     # Per-input token cap before sending to the embeddings endpoint.
                                      # Raise for longer-context models (e.g. text-embedding-qwen3-8b → 32768).
                                      # Oversized inputs are char-truncated client-side to avoid HTTP 400
                                      # "Input text exceeds the maximum token limit" errors.
# USE_OPENAI_EMBEDDINGS controls the EMBEDDING transport, not the provider:
#   true  → hit EMBEDDING_MODEL via the OpenAI-compatible HTTP API (works for
#           OpenAI, OpenRouter, vLLM — anything serving /v1/embeddings).
#           Required for Qwen3-Embedding-8B, text-embedding-3-small, etc.
#   false → IGNORE EMBEDDING_MODEL entirely and run sentence-transformers/
#           all-MiniLM-L6-v2 locally inside the container (no API call, no GPU).
USE_OPENAI_EMBEDDINGS=true
# EMBEDDING_API_BASE=            # API base URL for embeddings (defaults to OPENAI_API_BASE if not set)
# EMBEDDING_API_KEY=             # API key for embeddings (defaults to OPENAI_API_KEY if not set)

# =============================================================================
# Document Processing Configuration
# =============================================================================

# Docling Worker - Memory limits for large PDFs (avoids OOM exit -9)
# DOCLING_PAGE_CHUNK_SIZE=50       # Pages per chunk when processing large PDFs
# DOCLING_MAX_PAGES_PER_CHUNK=50   # Trigger chunked processing above this page count
# DOCLING_USE_PYPDFIUM_FOR_LARGE_MB=0  # Use memory-efficient backend for files > N MB (0=disabled)

# Upload Configuration
UPLOAD_DIR=/app/uploads
CUSTOM_INPUTS_DIR=/app/custom_inputs
MAX_FILE_SIZE_MB=50

# Resource Limits (0 = unlimited).
MAX_FILES=0
MAX_ENTITIES=0
MAX_COLLECTIONS=0
MAX_QUERIES_PER_MONTH=0  # ask + search calls per UTC month, instance-wide. 0 = unlimited

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_BY=sentence
SENTENCES_PER_CHUNK=5

# =============================================================================
# GraphRAG Configuration
# =============================================================================

# Graph Extraction
ENABLE_GRAPH_EXTRACTION=true
# GRAPH_EXTRACTION_MODEL=           # Model for entity extraction (defaults to OPENAI_MODEL)
# GRAPH_EXTRACTION_API_BASE=        # API base for extraction model (defaults to OPENAI_API_BASE)
# GRAPH_EXTRACTION_API_KEY=         # API key for extraction model (defaults to OPENAI_API_KEY)
# Tip: Use a small multimodal model (e.g. 8B) for both GRAPH_EXTRACTION_MODEL and VISION_MODEL
# to get fast extraction + image analysis from the same endpoint.

# Reasoning Control for ingestion pipelines
# Forces reasoning OFF on capable models (GPT-5/5.1, Claude 4.x, Qwen3, DeepSeek-R1,
# MiniMax M3) for structured extraction. No-op for pure
# instruct models. Works across OpenAI, OpenRouter, Venice, Anthropic, vLLM.
# Values: off | minimal | auto | low | medium | high
EXTRACTION_REASONING_MODE=off       # entity extraction + summaries + community naming
RELATIONSHIP_REASONING_MODE=off     # candidate scan, per-chunk + batch relationship extraction
VISION_REASONING_MODE=off           # image analysis (e.g. Qwen3-VL-27B without <think> tokens)
DEFAULT_REASONING_MODE=off          # Q&A / researcher agent + writer. OFF keeps chat time-to-first-token
                                    # <1s on reasoning-capable models (hidden chain-of-thought otherwise
                                    # adds 3-14s and can exhaust the budget into empty answers). Deep
                                    # research (quality mode) keeps reasoning regardless. Set "auto" to
                                    # restore provider-default thinking on chat.
# Escape hatch for novel models the heuristics get wrong.
# Format: "model1:mode1,model2:mode2"
# Example: REASONING_MODEL_OVERRIDES=gpt-5.8:none,custom-llm:minimal
# REASONING_MODEL_OVERRIDES=

MAX_GRAPH_HOPS=2
CONCURRENT_EXTRACTIONS=3           # entity-extraction threads per doc (bench-validated: 4 on Venice/large vLLM)

# Batch Processing Configuration
BATCH_PROCESSING_CONCURRENCY=2     # docs processed in parallel (bench-validated: 3 — see performance block above)
PROCESSING_THREAD_WORKERS=4

# Enhanced RAG Configuration
ENABLE_RERANKING=true
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_HYBRID_SEARCH=true
VECTOR_WEIGHT=0.5
KEYWORD_WEIGHT=0.3
GRAPH_WEIGHT=0.2
MAX_CONVERSATION_HISTORY=6              # Legacy count cap; used only when no conversation_memory blob is sent
ENABLE_AGENTIC_RAG=true
MAX_AGENTIC_STEPS=3

# Conversation Memory / Context Curator (client-carried multi-bucket memory).
# Active only when the client sends a `conversation_memory` blob; absent => legacy truncation.
ENABLE_CONVERSATION_MEMORY=true         # Backend kill-switch (client opt-in via the blob still required)
# CONVERSATION_MEMORY_WINDOW=6          # Recent messages kept verbatim; older ones fold into rolling summary
# CONVERSATION_MEMORY_COMPACTION_MODEL= # Model for post-stream compaction (empty => fast-mode model)
# CONVERSATION_MEMORY_MAX_LEDGER=50     # Max source_ledger entries kept in the blob (citation continuity via stable sid)
ENABLE_MEMORY_FAST_PATH=true            # Let memory-answerable follow-ups skip retrieval (cheap classifier decides)

# Agent-based Research Pipeline (researcher/writer architecture)
ENABLE_AGENT_RESEARCH=true              # Use agent pipeline for deep research mode (set false for legacy)
ENABLE_AGENT_CHAT=true                  # Use agent pipeline for standard chat mode (required for skills in chat)
# RESEARCHER_MAX_ITERATIONS_SPEED=3     # Max agent loop iterations in chat mode
# RESEARCHER_MAX_ITERATIONS_QUALITY=8   # Max agent loop iterations in deep research mode
# WRITER_MAX_TOKENS_SPEED=1200          # Max output tokens for chat answers
# WRITER_MAX_TOKENS_QUALITY=4000        # Max output tokens for deep research answers
#
# Loop efficiency (all default true; set false to restore legacy behavior)
# RESEARCHER_SPEED_EARLY_WRITE=true     # Chat: skip the final "research complete" confirmation LLM call
# RESEARCHER_PARALLEL_TOOL_CALLS=true   # Run read-only searches from one agent turn concurrently
# RESEARCHER_TOOL_ENTITY_HINTS=true     # Agent supplies entities on search calls (skips extraction call)
# RESEARCHER_SEARCH_DEDUP=true          # Identical repeat searches served from a per-question cache
# RESEARCHER_FORCE_GROUNDING=true       # If the loop ends with zero searches, force one raw-question search before writing
# EMIT_DONE_BEFORE_MEMORY=true          # SSE `done` (pending_memory: true) before memory compaction;
#                                       # memory_update follows — clients must read the stream to its end

# =============================================================================
# Budget Fallback Chain (Output Tokens + Input Context)
# =============================================================================
# All knobs default to 0 (= inherit from the next tier up). Override any tier
# explicitly to break the chain at that point.
#
#   OUTPUT:  OPENAI_MAX_OUTPUT_TOKENS
#                ↓
#            EXTRACTION_MAX_OUTPUT_TOKENS   ← entity extraction
#                ↓
#            RELATIONSHIP_MAX_OUTPUT_TOKENS ← per-chunk + candidate-pair scan
#                ↓
#            VISION_MAX_OUTPUT_TOKENS       ← image analysis
#
#            RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS = 16000  (standalone, Phase 2 only)
#
#   INPUT:   OPENAI_MAX_CONTEXT
#                ↓
#            GRAPH_EXTRACTION_MAX_CONTEXT
#                ↓
#            RELATIONSHIP_MAX_CONTEXT
#
# Tip for Qwen3-family models: raise EXTRACTION_MAX_OUTPUT_TOKENS to 3500–4000
# because they emit more verbose XML than instruct models and otherwise
# truncate before finishing the <relationship> list.
#
# EXTRACTION_MAX_OUTPUT_TOKENS=0         # entity extraction (3 call sites)
# RELATIONSHIP_MAX_OUTPUT_TOKENS=0       # per-chunk + candidate scan
# RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS=16000  # Phase 2 batch (standalone, NOT in chain)
# VISION_MAX_OUTPUT_TOKENS=0             # image-description calls
# GRAPH_EXTRACTION_MAX_CONTEXT=0               # input batching for entity extraction
# RELATIONSHIP_MAX_CONTEXT=0             # input batching for Phase 2 relationship analysis
#
# Migration note: if you previously set RELATIONSHIP_MAX_OUTPUT_TOKENS=16000
# to control Phase 2 batch, that semantic now lives in
# RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS. The old name now feeds per-chunk +
# candidate scan instead (16000 there is harmless overkill — model finishes
# well under cap — but a stale 16000 won't help). Migrate when convenient.

# Relationship Analysis (Phase B - cross-document relationship discovery, Step 2)
# Default mode 'targeted': candidate pairs come from the entity-embedding
# vector index (kNN) + document co-mention — no LLM — and the LLM only
# verifies/classifies ranked pairs in small batched calls. Orders of magnitude
# faster than the legacy full-batch scan on large graphs (hours → minutes).
# RELATIONSHIP_DISCOVERY_MODE=targeted          # 'targeted' | 'llm_scan' (legacy two-phase batch scan)
# RELATIONSHIP_KNN_K=8                          # Nearest neighbors per entity in the vector-index scan
# RELATIONSHIP_KNN_MIN_SIMILARITY=0.80          # Min Neo4j vector-index score for a kNN candidate pair
# RELATIONSHIP_MIN_SHARED_DOCS=2                # Min docs co-mentioning a pair (0 = disable co-mention generator)
# RELATIONSHIP_DOC_FREQ_CAP=30                  # Skip hub entities mentioned in more docs than this (co-mention generator)
# RELATIONSHIP_MAX_CANDIDATE_PAIRS=15000        # Total candidate-pair budget per run (top-ranked kept)
# RELATIONSHIP_CANDIDATES_PER_ENTITY=10         # Max candidate pairs per entity (hub guard)
# RELATIONSHIP_PAIRS_PER_CALL=40                # Candidate pairs verified per LLM call
# RELATIONSHIP_PAIR_CONTEXT_TOKENS=3000         # Chunk-context tokens per verification call (0 = descriptions only)
# Shared knobs (both modes):
# PARALLEL_RELATIONSHIP_BATCHES=0               # Parallel LLM verification calls / batches (0 = use CONCURRENT_EXTRACTIONS)
# RELATIONSHIP_MAX_HOURS=0                      # Max hours for relationship generation (0 = no time limit)
# RELATIONSHIP_MAX_PER_ENTITY=50                 # Soft cap on relationships per entity (0 = no cap)
# Legacy llm_scan mode only:
# RELATIONSHIP_TARGET_RATIO=1.0                 # Target relationships-per-entity ratio (ERR) for admin monitoring
# RELATIONSHIP_MAX_ROUNDS=3                     # Max auto-discovery rounds for initial analysis (re-analyze always does 1 round)

# Community Detection & Graph Summarization
ENABLE_COMMUNITY_DETECTION=true
MIN_COMMUNITY_SIZE=3
MAX_COMMUNITIES=50
ENABLE_GRAPH_SUMMARIZATION=true    # Community names/summaries run on the extraction tier (GRAPH_EXTRACTION_MODEL)

# Semantic Entity Resolution
ENABLE_SEMANTIC_ENTITY_RESOLUTION=true
ENTITY_SIMILARITY_THRESHOLD=0.85
# ENTITY_EMBEDDING_MODEL=  # Defaults to EMBEDDING_MODEL if not set

# Collection-Level Graphs
ENABLE_COLLECTIONS=true
DEFAULT_COLLECTION=default

# Git Integration (connect GitHub/GitLab/Gitea repos — disabled by default)
ENABLE_GIT_INTEGRATION=false
GIT_WORK_DIR=./git_repos                 # Clone working-copy cache (mount a volume in prod)
GIT_CLONE_DEPTH=1                        # Shallow-clone depth
GIT_MAX_REPO_SIZE_MB=500                 # Abort sync above this size (0 = unlimited)
GIT_SYNC_MAX_FILE_SIZE_MB=5              # Skip files larger than this (0 = no limit)
GIT_SYNC_POLL_INTERVAL=5                 # Minutes between scheduled-sync checks
GIT_HTTP_TIMEOUT=30                      # Timeout (s) for git provider REST calls
GIT_HTTP_INSECURE_HOSTS=                 # Comma-sep hosts to skip TLS (self-hosted self-signed)

# Web Import — MDHarvest powered by Crawl4ai (web → markdown; disabled by default).
# Cortex never runs a browser; it calls a crawl4ai service over HTTP. Run crawl4ai
# yourself (docker run -p 11235:11235 --shm-size=1g -e CRAWL4AI_API_TOKEN=<token>
# unclecode/crawl4ai) and set the URL + matching token below.
ENABLE_WEB_CRAWL=false
CRAWL_SERVICE_URL=                       # e.g. http://crawl4ai:11235 — empty = feature off
CRAWL_SERVICE_TOKEN=                     # Bearer token; must match crawl4ai's CRAWL4AI_API_TOKEN.
                                         # Required for crawl4ai >= 0.9.0 (tokenless binds 127.0.0.1 only).
CRAWL_CONTENT_FILTER=fit                 # fit (readable) | raw (full page) | bm25 (ranked)
CRAWL_HTTP_TIMEOUT=60                    # Per-page crawl timeout (seconds)
CRAWL_CONCURRENCY=5                      # URLs crawled at once per import job
CRAWL_MAX_URLS_PER_JOB=100               # Max URLs per import (0 = unlimited)
CRAWL_DISCOVER_MAX_LINKS=200             # Cap on links returned by Discover

# Extended Thinking / Reasoning Visibility
STREAM_REASONING_STEPS=true
SHOW_RETRIEVAL_STATS=true
# Show advanced tuning knobs (output-token budgets, concurrency, chunking, weights,
# graph hops, thresholds, ...) in the admin System Config panel. false = curated view.
DISPLAY_FULL_SYSTEM_CONFIG=false

# Prompt Security (protection against prompt injection attacks)
PROMPT_SECURITY=true

# =============================================================================
# Admin Authentication
# =============================================================================
# These credentials are used for admin login to the frontend
# The admin API key grants full access to all backend endpoints

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_API_KEY=cortex_admin_your-secure-api-key-here
SESSION_SECRET=your-session-secret-key-at-least-32-characters-long

# Track usage analytics for admin API key (default: false)
# TRACK_ADMIN_API_KEY_USAGE=false

# =============================================================================
# Secret Encryption (at rest)
# =============================================================================
# Encrypts user-supplied secrets at rest: git connector PATs (stored in Neo4j)
# and secret-typed skill config fields (stored in config.json files).
# Without a key, secrets are stored in PLAINTEXT (a warning is logged at startup).
# Setting a key later automatically encrypts existing plaintext secrets on the
# next startup.
#
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Key rotation (zero downtime): prepend the new key, keep the old one —
#   ENCRYPTION_KEY=<new-key>,<old-key>
# Restart (startup re-encrypts everything with the new key), then drop the old key.
# ENCRYPTION_KEY=

# =============================================================================
# Observability (Langfuse) — optional
# =============================================================================
# Traces every LLM / embedding / vision call (cost, tokens, latency, errors)
# and groups agentic Q&A flows into one trace per request. Self-hostable; data
# stays in your infra. Leave all three blank to run untraced — the same image
# behaves identically with or without these set (no keys = no tracing).
#
# Point at a Langfuse instance and paste a project's public/secret key pair
# (Langfuse → Project Settings → API Keys). See .claude/domain/observability.md.
# LANGFUSE_BASE_URL=https://langfuse.example.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_TRACING_ENABLED=true   # master off-switch even when keys are set
# LANGFUSE_SAMPLE_RATE=1.0        # 0.0–1.0; lower to sample on hot instances
# LANGFUSE_LOG_EXTENDED=false     # false (default) redacts ALL prompt/completion/
#                                 # tool/embedding/vision text before export, keeping
#                                 # only structure (roles, model, tool names + arg
#                                 # keys, tokens, cost). true logs full content for
#                                 # local debugging.

# =============================================================================
# Frontend Configuration
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000

# Custom Logo URL (optional)
# If set, the logo will be replaced with the image from this URL
# NEXT_PUBLIC_LOGO_URL=https://example.com/logo.png

# Custom Accent Color (optional)
# If set, overrides the default accent color in the UI
# Accepts any valid CSS color value (hex, rgb, hsl, oklch, etc.)
# Deliberately NOT NEXT_PUBLIC_-prefixed: it's read server-side at runtime
# (layout.tsx), so changing it needs no frontend rebuild.
# Examples:
#   ACCENT_COLOR=#3b82f6
#   ACCENT_COLOR=rgb(59, 130, 246)
#   ACCENT_COLOR=oklch(0.65 0.2 250)
# ACCENT_COLOR=

# =============================================================================
# Vision Model Examples
# =============================================================================
# Example configurations for different vision model providers:

# OpenAI GPT-4 Vision
# VISION_MODEL=gpt-4o
# VISION_MODEL_API_BASE=https://api.openai.com/v1
# VISION_MODEL_API_KEY=sk-your-openai-api-key

# Anthropic Claude 3.5 Sonnet
# VISION_MODEL=claude-3-5-sonnet-20241022
# VISION_MODEL_API_BASE=https://api.anthropic.com/v1
# VISION_MODEL_API_KEY=your-anthropic-api-key

# Local Model via Ollama (LLaVA)
# VISION_MODEL=llava
# VISION_MODEL_API_BASE=http://localhost:11434/v1
# VISION_MODEL_API_KEY=ollama

# Custom OpenAI-Compatible Vision API
# VISION_MODEL=your-model-name
# VISION_MODEL_API_BASE=https://your-api-endpoint.com/v1
# VISION_MODEL_API_KEY=your-api-key

# =============================================================================
# v-Next: Efficiency flags (default OFF — enable after a bench A/B run,
# see bench/BASELINE.md) and production hardening
# =============================================================================

# --- KG building efficiency ---
# ENTITY_DEDUP_PREFILTER=true          # Levenshtein dedup over top-50 fulltext candidates instead of a full Entity scan
# ENABLE_BATCHED_KG_WRITES=true        # UNWIND-batched entity/link/relationship writes (~5-10 round trips per doc instead of hundreds)
# ENABLE_BATCHED_CHUNK_RELATIONSHIPS=true  # DEFAULT ON — several chunks per relationship-extraction LLM call
#                                          # (4x fewer Step 1 calls at parity yield; the big lever when your
#                                          # LLM provider rate-limits requests/min). Set false for one call per chunk.
# RELATIONSHIP_CHUNKS_PER_CALL=4           # 4 validated; 6 also passed A/B (fewer calls, slightly longer per call)
# ENABLE_PHASEB_CHECKPOINTING=true     # resume Phase B after crash/redeploy; reuse Phase 1 candidates across rounds
# ENABLE_REPROCESS_DELTA=true          # skip reprocessing when file bytes + extraction config are unchanged

# --- Prompt caching ---
# RESEARCHER_STABLE_PROMPT=true        # (default true) byte-stable researcher system prompt across iterations
# ENABLE_PROMPT_CACHE_CONTROL=true     # Anthropic cache_control via OpenRouter (anthropic/* models only)

# --- Retrieval budgets ---
# RESEARCHER_WALL_CLOCK_SECONDS=120    # 0 = unlimited (default); on expiry the writer synthesizes from gathered results
# RERANK_TOP_K=15                      # rerank candidate pool per knowledge_search

# --- Shared model service (cortex-helper) — offload reranker + Docling to one per-host service ---
# Point both at the same cortex-helper base URL. Empty => use the built-in local
# reranker (in-process cross-encoder) + Docling (subprocess) path. In the AaaS
# cloud these are injected per-tenant by meta-cortex; set them by hand for a
# self-hosted multi-stack box running its own cortex-helper.
# RERANKER_SERVICE_URL=https://helper.cortex.qwellco.de   # POSTs {query,passages} to /rerank
# DOCLING_SERVICE_URL=https://helper.cortex.qwellco.de    # POSTs the file to /convert
# HELPER_SERVICE_TOKEN=...              # sent as X-Helper-Token; MUST match the helper's HELPER_TOKEN
# HELPER_STRICT_REMOTE=true            # conversion failure = document failed (no local docling fallback into the tenant container)
# INSTANCE_ID=customer-acme            # X-Tenant-ID for fair queuing at the helper (default: container hostname)

# --- Observability & limits ---
# LOG_FORMAT=json                      # default "plain" (legacy format); json adds request_id correlation
# METRICS_ENABLED=true                 # GET /metrics (admin-key protected)
# EXPOSE_API_DOCS=auto                 # /docs,/redoc,/openapi.json — "auto" = on in dev, OFF in production; true/false to force
# RATE_LIMIT_QPM=60                    # per-API-key requests/minute on ask/upload (0 = off); RATE_LIMIT_BURST=10
# NEO4J_MAX_POOL_SIZE=100
# NEO4J_CONNECTION_TIMEOUT=10
# NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# --- Compose-level memory caps (docker-compose*.yml) ---
# NOTE: the neo4j caps are deliberately NOT prefixed NEO4J_. PaaS platforms
# (Coolify/Dokploy) inject every env var into every container, and neo4j parses
# any NEO4J_*-prefixed var as a config setting -> strict_validation refuses to
# boot. Keep the CORTEX_NEO4J_ prefix.
# CORTEX_NEO4J_MEM_LIMIT=4g
# CORTEX_NEO4J_HEAP_INITIAL=512m
# CORTEX_NEO4J_HEAP_MAX=2G
# CORTEX_NEO4J_PAGECACHE=512m
# FRONTEND_MEM_LIMIT=1g

# --- Backups (docker-compose.backup.yml overlay) ---
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_RETENTION_DAYS=7
# NEO4J_ENTERPRISE_BACKUP=false
