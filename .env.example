# =============================================================================
# Cortex - Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings

# =============================================================================
# QUICK START — Recommended Minimal Stack (bench-validated)
# =============================================================================
# Two models, everything else inherited via the budget chain.
# Requires a provider hosting both (OpenRouter, self-hosted vLLM,
# Compute3, or any OpenAI-compatible router).
#
# Uncomment + fill in the two API values, then scroll down to set
# NEO4J_PASSWORD and the ADMIN_* / SESSION_SECRET block. That's it.

# Primary — agentic Q&A / researcher (MiniMax-M2.7: 196K context window)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.venice.ai/api/v1
# OPENAI_MODEL=minimax-m27
# OPENAI_MAX_CONTEXT=196608

# Extraction — drives relationship via inheritance (Qwen3.7-27B: 256K window)
# GRAPH_EXTRACTION_MODEL=qwen3-6-27b
# GRAPH_EXTRACTION_MAX_CONTEXT=256000

# Vision — image analysis (does NOT inherit; api_base/api_key inherit from OPENAI_*)
# VISION_MODEL=qwen3-6-27b

# Embeddings — text embedding model (Qwen3-Embedding-8B: native 4096 dim, MRL-configurable 32–4096)
# Uses primary OPENAI_API_BASE + OPENAI_API_KEY unless EMBEDDING_API_BASE/_KEY are set.
# EMBEDDING_SEND_DIMENSIONS=true (default) works because Qwen3-Embedding-8B supports MRL.
# EMBEDDING_MODEL=text-embedding-qwen3-8b
# EMBEDDING_DIMENSION=4096   # Native dimension for Qwen3-Embedding-8B; supported by Neo4j 5.23+
                             # (this repo ships Neo4j 5.26 — see docker-compose.yml).
                             # Existing instances on Neo4j ≤ 5.20 with 1536/2048-dim corpora
                             # can keep their dim — Cortex preserves the index when EMBEDDING_DIMENSION
                             # matches the existing one. Only bumping the dim triggers a re-embed.

# -----------------------------------------------------------------------------
# Performance tuning (Venice-validated — pair these with the Recommended Stack above)
# -----------------------------------------------------------------------------
# Bench-validated against Venice as the LLM provider. Safe on Venice /
# Compute3 / large vLLM endpoints; dial back on stock OpenAI or smaller hosts.
# In practice the ingestion pipeline staggers entity extraction, per-chunk
# relationships, and vision across each doc's lifecycle, so actual concurrent
# in-flight calls stays well below the worst-case theoretical product.
#
# BATCH_PROCESSING_CONCURRENCY=5    # docs processed in parallel (default 2 — bump for batch ingestion)
# CONCURRENT_EXTRACTIONS=10         # entity-extraction threads per doc (default 3 — biggest multiplier)
# CONCURRENT_RELATIONS=5            # per-chunk relationship threads per doc (default 3)
# VISION_MAX_CONCURRENT=5           # system-wide vision-API semaphore (default 3)

# =============================================================================
# Core Services
# =============================================================================

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here

# OpenAI / LiteLLM Configuration
# Required for GraphRAG features (entity extraction, Q&A, summarization)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_FAST_MODE=gpt-4o-mini  # Optional: faster/cheaper model for "Fast Mode" in Ask AI (defaults to OPENAI_MODEL)

# Primary token budgets — sub-tiers (extraction / relationship / vision)
# inherit when their override is left at the default (0). This lets you
# configure a 3-model stack with just OPENAI_MODEL + GRAPH_EXTRACTION_MODEL
# and have everything else flow through. See the "Budget Fallback Chain"
# section further down for the full chain.
OPENAI_MAX_OUTPUT_TOKENS=8000      # Default output tokens for every LLM call
OPENAI_MAX_CONTEXT=32768           # Default input context budget

# =============================================================================
# Vision Model Configuration (Optional)
# =============================================================================
# Configure vision models for image extraction and analysis
# If not configured, system uses Docling's built-in descriptions or basic metadata

# Vision Model - Examples:
#   - OpenAI: gpt-4o, gpt-4-vision-preview
#   - Anthropic: claude-3-5-sonnet-20241022
#   - Local: llava (via Ollama)
# VISION_MODEL=gpt-4o

# Vision Model API Base URL (defaults to OPENAI_API_BASE if not set)
# VISION_MODEL_API_BASE=https://api.openai.com/v1

# Vision Model API Key (defaults to OPENAI_API_KEY if not set)
# VISION_MODEL_API_KEY=sk-your-vision-api-key-here

# Max concurrent vision API calls system-wide (default: 3)
# Increase for faster image-heavy document processing. Each slot uses one thread.
# VISION_MAX_CONCURRENT=3

# Vision output budget override (0 = inherit from RELATIONSHIP → EXTRACTION → OPENAI).
# Bump when using verbose multimodal models (Qwen3-VL, GLM-V) on complex images.
# VISION_MAX_OUTPUT_TOKENS=0

# =============================================================================
# Embedding Configuration
# =============================================================================

EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_SEND_DIMENSIONS=true        # Set to false for models with fixed output dimensions (e.g. qwen3-vl-embedding-2b)
# USE_OPENAI_EMBEDDINGS controls the EMBEDDING transport, not the provider:
#   true  → hit EMBEDDING_MODEL via the OpenAI-compatible HTTP API (works for
#           OpenAI, OpenRouter, vLLM, Compute3 — anything serving /v1/embeddings).
#           Required for Qwen3-Embedding-8B, text-embedding-3-small, etc.
#   false → IGNORE EMBEDDING_MODEL entirely and run sentence-transformers/
#           all-MiniLM-L6-v2 locally inside the container (no API call, no GPU).
USE_OPENAI_EMBEDDINGS=true
# EMBEDDING_API_BASE=            # API base URL for embeddings (defaults to OPENAI_API_BASE if not set)
# EMBEDDING_API_KEY=             # API key for embeddings (defaults to OPENAI_API_KEY if not set)

# =============================================================================
# Document Processing Configuration
# =============================================================================

# Docling Worker - Memory limits for large PDFs (avoids OOM exit -9)
# DOCLING_PAGE_CHUNK_SIZE=50       # Pages per chunk when processing large PDFs
# DOCLING_MAX_PAGES_PER_CHUNK=50   # Trigger chunked processing above this page count
# DOCLING_USE_PYPDFIUM_FOR_LARGE_MB=0  # Use memory-efficient backend for files > N MB (0=disabled)

# Upload Configuration
UPLOAD_DIR=/app/uploads
CUSTOM_INPUTS_DIR=/app/custom_inputs
MAX_FILE_SIZE_MB=50

# Resource Limits (0 = unlimited). See PRICING.md for per-tier values.
MAX_FILES=0
MAX_ENTITIES=0
MAX_COLLECTIONS=0
MAX_QUERIES_PER_MONTH=0  # ask + search calls per UTC month, instance-wide. 0 = unlimited

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_BY=sentence
SENTENCES_PER_CHUNK=5

# =============================================================================
# GraphRAG Configuration
# =============================================================================

# Graph Extraction
ENABLE_GRAPH_EXTRACTION=true
# GRAPH_EXTRACTION_MODEL=           # Model for entity extraction (defaults to OPENAI_MODEL)
# GRAPH_EXTRACTION_API_BASE=        # API base for extraction model (defaults to OPENAI_API_BASE)
# GRAPH_EXTRACTION_API_KEY=         # API key for extraction model (defaults to OPENAI_API_KEY)
# Tip: Use a small multimodal model (e.g. 8B) for both GRAPH_EXTRACTION_MODEL and VISION_MODEL
# to get fast extraction + image analysis from the same endpoint.

# Reasoning Control for ingestion pipelines
# Forces reasoning OFF on capable models (GPT-5/5.1, Claude 4.x, Qwen3, DeepSeek-R1,
# GLM-4.6, Kimi K2, MiniMax M2) for structured extraction. No-op for pure
# instruct models. Works across OpenAI, OpenRouter, Venice, Anthropic, vLLM/Compute3.
# Values: off | minimal | auto | low | medium | high
EXTRACTION_REASONING_MODE=off       # entity extraction + summaries + community naming
RELATIONSHIP_REASONING_MODE=off     # candidate scan, per-chunk + batch relationship extraction
VISION_REASONING_MODE=off           # image analysis (e.g. Qwen3-VL-27B without <think> tokens)
DEFAULT_REASONING_MODE=auto         # Q&A / researcher agent — leave provider default
# Escape hatch for novel models the heuristics get wrong.
# Format: "model1:mode1,model2:mode2"
# Example: REASONING_MODEL_OVERRIDES=gpt-5.8:none,custom-llm:minimal
# REASONING_MODEL_OVERRIDES=

MAX_GRAPH_HOPS=2
CONCURRENT_EXTRACTIONS=20

# Batch Processing Configuration
BATCH_PROCESSING_CONCURRENCY=10
PROCESSING_THREAD_WORKERS=4

# Enhanced RAG Configuration
ENABLE_RERANKING=true
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_HYBRID_SEARCH=true
VECTOR_WEIGHT=0.5
KEYWORD_WEIGHT=0.3
GRAPH_WEIGHT=0.2
MAX_CONVERSATION_HISTORY=6
ENABLE_AGENTIC_RAG=true
MAX_AGENTIC_STEPS=3

# Agent-based Research Pipeline (researcher/writer architecture)
ENABLE_AGENT_RESEARCH=true              # Use agent pipeline for deep research mode (set false for legacy)
ENABLE_AGENT_CHAT=true                  # Use agent pipeline for standard chat mode (required for skills in chat)
# RESEARCHER_MAX_ITERATIONS_SPEED=5     # Max agent loop iterations in chat mode
# RESEARCHER_MAX_ITERATIONS_QUALITY=10  # Max agent loop iterations in deep research mode
# WRITER_MAX_TOKENS_SPEED=1200          # Max output tokens for chat answers
# WRITER_MAX_TOKENS_QUALITY=4000        # Max output tokens for deep research answers

# =============================================================================
# Budget Fallback Chain (Output Tokens + Input Context)
# =============================================================================
# All knobs default to 0 (= inherit from the next tier up). Override any tier
# explicitly to break the chain at that point.
#
#   OUTPUT:  OPENAI_MAX_OUTPUT_TOKENS
#                ↓
#            EXTRACTION_MAX_OUTPUT_TOKENS   ← entity extraction
#                ↓
#            RELATIONSHIP_MAX_OUTPUT_TOKENS ← per-chunk + candidate-pair scan
#                ↓
#            VISION_MAX_OUTPUT_TOKENS       ← image analysis
#
#            RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS = 16000  (standalone, Phase 2 only)
#
#   INPUT:   OPENAI_MAX_CONTEXT
#                ↓
#            GRAPH_EXTRACTION_MAX_CONTEXT
#                ↓
#            RELATIONSHIP_MAX_CONTEXT
#
# Tip for Qwen3-family models: raise EXTRACTION_MAX_OUTPUT_TOKENS to 3500–4000
# because they emit more verbose XML than instruct models and otherwise
# truncate before finishing the <relationship> list.
#
# EXTRACTION_MAX_OUTPUT_TOKENS=0         # entity extraction (3 call sites)
# RELATIONSHIP_MAX_OUTPUT_TOKENS=0       # per-chunk + candidate scan
# RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS=16000  # Phase 2 batch (standalone, NOT in chain)
# VISION_MAX_OUTPUT_TOKENS=0             # image-description calls
# GRAPH_EXTRACTION_MAX_CONTEXT=0               # input batching for entity extraction
# RELATIONSHIP_MAX_CONTEXT=0             # input batching for Phase 2 relationship analysis
#
# Migration note: if you previously set RELATIONSHIP_MAX_OUTPUT_TOKENS=16000
# to control Phase 2 batch, that semantic now lives in
# RELATIONSHIP_BATCH_MAX_OUTPUT_TOKENS. The old name now feeds per-chunk +
# candidate scan instead (16000 there is harmless overkill — model finishes
# well under cap — but a stale 16000 won't help). Migrate when convenient.

# Relationship Analysis (Phase B - two-phase cross-document relationship discovery)
# Phase 1 (extraction model): scans entity batches for candidate pairs
# Phase 2 (extraction model): confirms candidates with structured XML output
# Uses co-occurrence-based batching (Union-Find clustering) and dynamic chunk context filling
# PARALLEL_RELATIONSHIP_BATCHES=0               # Number of batches to process in parallel (0 = use CONCURRENT_EXTRACTIONS)
# RELATIONSHIP_TARGET_RATIO=1.0                 # Target relationships-per-entity ratio (ERR) for admin monitoring
# RELATIONSHIP_MAX_ROUNDS=3                     # Max auto-discovery rounds for initial analysis (re-analyze always does 1 round)
# RELATIONSHIP_MAX_HOURS=0                      # Max hours for relationship generation (0 = no time limit)
# RELATIONSHIP_MAX_PER_ENTITY=50                 # Soft cap on relationships per entity (0 = no cap)

# Community Detection & Graph Summarization
ENABLE_COMMUNITY_DETECTION=true
MIN_COMMUNITY_SIZE=3
MAX_COMMUNITIES=50
ENABLE_GRAPH_SUMMARIZATION=true
# COMMUNITY_SUMMARY_MODEL=  # Defaults to OPENAI_MODEL if not set

# Semantic Entity Resolution
ENABLE_SEMANTIC_ENTITY_RESOLUTION=true
ENTITY_SIMILARITY_THRESHOLD=0.85
# ENTITY_EMBEDDING_MODEL=  # Defaults to EMBEDDING_MODEL if not set

# Collection-Level Graphs
ENABLE_COLLECTIONS=true
DEFAULT_COLLECTION=default

# Extended Thinking / Reasoning Visibility
STREAM_REASONING_STEPS=true
SHOW_RETRIEVAL_STATS=true

# Prompt Security (protection against prompt injection attacks)
PROMPT_SECURITY=true

# =============================================================================
# Admin Authentication
# =============================================================================
# These credentials are used for admin login to the frontend
# The admin API key grants full access to all backend endpoints

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_API_KEY=cortex_admin_your-secure-api-key-here
SESSION_SECRET=your-session-secret-key-at-least-32-characters-long

# Track usage analytics for admin API key (default: false)
# TRACK_ADMIN_API_KEY_USAGE=false

# =============================================================================
# Frontend Configuration
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000

# Custom Logo URL (optional)
# If set, the logo will be replaced with the image from this URL
# NEXT_PUBLIC_LOGO_URL=https://example.com/logo.png

# Custom Accent Color (optional)
# If set, overrides the default accent color in the UI
# Accepts any valid CSS color value (hex, rgb, hsl, oklch, etc.)
# Examples:
#   NEXT_PUBLIC_ACCENT_COLOR=#3b82f6
#   NEXT_PUBLIC_ACCENT_COLOR=rgb(59, 130, 246)
#   NEXT_PUBLIC_ACCENT_COLOR=oklch(0.65 0.2 250)
# NEXT_PUBLIC_ACCENT_COLOR=

# =============================================================================
# Compute3 Turbo Mode Configuration (ON HOLD — feature not currently live)
# =============================================================================
# Compute3 partnership prepared in 2025; their service is not yet in
# production, so this feature is non-functional today. Vars below have
# no effect at runtime — left here against future activation. Leave them
# all commented out unless you've been instructed otherwise.

# COMPUTE3_API_KEY=your-c3-api-key-here
# COMPUTE3_API_BASE=https://api.compute3.ai
# COMPUTE3_GPU_TYPE=h100
# COMPUTE3_GPU_COUNT=4
# COMPUTE3_MODEL=MiniMaxAI/MiniMax-M2.1
# COMPUTE3_DOCKER_IMAGE=vllm/vllm-openai:latest
# COMPUTE3_DEFAULT_RUNTIME=3600

# Note: For newer models like MiniMax-M2.1, you may need a nightly vLLM image.
# Check available tags at: https://hub.docker.com/r/vllm/vllm-openai/tags
# Example nightly: vllm/vllm-openai:nightly

# =============================================================================
# Vision Model Examples
# =============================================================================
# Example configurations for different vision model providers:

# OpenAI GPT-4 Vision
# VISION_MODEL=gpt-4o
# VISION_MODEL_API_BASE=https://api.openai.com/v1
# VISION_MODEL_API_KEY=sk-your-openai-api-key

# Anthropic Claude 3.5 Sonnet
# VISION_MODEL=claude-3-5-sonnet-20241022
# VISION_MODEL_API_BASE=https://api.anthropic.com/v1
# VISION_MODEL_API_KEY=your-anthropic-api-key

# Local Model via Ollama (LLaVA)
# VISION_MODEL=llava
# VISION_MODEL_API_BASE=http://localhost:11434/v1
# VISION_MODEL_API_KEY=ollama

# Custom OpenAI-Compatible Vision API
# VISION_MODEL=your-model-name
# VISION_MODEL_API_BASE=https://your-api-endpoint.com/v1
# VISION_MODEL_API_KEY=your-api-key
