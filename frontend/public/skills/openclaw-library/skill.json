{
  "name": "openclaw-library",
  "version": "1.2.0",
  "description": "Sync OpenClaw memory files to MOCA Library knowledge graph for enhanced retrieval, search, and AI-powered Q&A.",
  "author": "MOCA",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "moltbot",
    "skill",
    "knowledge-graph",
    "memory",
    "rag",
    "search",
    "documents",
    "neo4j",
    "graphrag"
  ],
  "openclaw": {
    "emoji": "📚",
    "category": "knowledge",
    "requires": {
      "bins": ["curl", "jq"],
      "credentials": {
        "api_key": "REQUIRED - API key from YOUR_BASE_URL/admin/api-keys",
        "base_url": "REQUIRED - Full URL to your MOCA Library instance (e.g., https://library.example.com)"
      }
    },
    "triggers": [
      "sync memories",
      "sync to library",
      "upload memories",
      "upload to library",
      "search knowledge",
      "search my memories",
      "ask knowledge base",
      "what do I know about",
      "library sync",
      "knowledge graph"
    ],
    "state": {
      "credentials": "~/.openclaw/skills/library/state/credentials.json",
      "uploaded_files": "~/.openclaw/skills/library/state/uploaded_files.json"
    },
    "memory_directories": [
      "~/.openclaw/memory",
      "~/.openclaw/conversations"
    ],
    "supported_extensions": [".md", ".txt", ".json"],
    "sync_interval_hours": 4
  }
}
