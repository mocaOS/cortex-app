{
  "name": "library",
  "version": "2.0.0",
  "description": "Sync agent memory files to Cortex Library knowledge graph for enhanced retrieval, hybrid search, AI-powered Q&A with agentic deep research, and knowledge graph exploration.",
  "author": "Cortex",
  "license": "MIT",
  "keywords": [
    "agentskills",
    "knowledge-graph",
    "memory",
    "rag",
    "search",
    "documents",
    "neo4j",
    "graphrag",
    "deep-research",
    "collections",
    "communities",
    "hybrid-search",
    "agentic"
  ],
  "agentskills": {
    "standard": "1.0",
    "emoji": "\ud83d\udcda",
    "category": "knowledge",
    "requires": {
      "bins": ["curl", "jq"],
      "fallback_bins": ["python3"],
      "credentials": {
        "api_key": "REQUIRED - API key from YOUR_BASE_URL/admin -> API Keys",
        "base_url": "REQUIRED - Full URL to your Cortex Library instance (e.g., https://library.example.com)"
      }
    },
    "triggers": [
      "sync memories",
      "sync to library",
      "upload memories",
      "upload to library",
      "search knowledge",
      "search my memories",
      "ask knowledge base",
      "what do I know about",
      "library sync",
      "knowledge graph",
      "deep research",
      "search documents"
    ],
    "state": {
      "credentials": "~/.openclaw/skills/library/state/credentials.json",
      "uploaded_files": "~/.openclaw/skills/library/state/uploaded_files.json"
    },
    "memory_directories": [
      "~/.openclaw/memory",
      "~/.openclaw/conversations"
    ],
    "supported_extensions": [".md", ".txt", ".json"],
    "sync_interval_hours": 4
  }
}
