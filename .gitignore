# Bench harness — input docs, run outputs, and locally-edited config stay out of git.
# The orchestrator code and .yaml.example templates ARE tracked.
# NOTE: `!bench/logs/` overrides the broader `logs/` rule above so we can keep
# the directory present with a .gitkeep while ignoring its contents.
!bench/logs/
bench/files/*
!bench/files/.gitkeep
bench/logs/*
!bench/logs/.gitkeep
bench/backups/*
!bench/backups/.gitkeep
bench/models.yaml
bench/combos.yaml
bench/qa_models.yaml
bench/_probe_thinking.py
bench/__pycache__/

# Skills *.zip
library.zip
# Git connector clone working copies
backend/git_repos/
git_repos/

# Claude Code scheduled-tasks lock (machine-local state)
.claude/scheduled_tasks.lock

# Venice capacity-planning report (local working doc, never commit)
venice.md
venice-projection.ods
HANDOVER-BUILDER.md
HANDOVER-FINANCE.md
